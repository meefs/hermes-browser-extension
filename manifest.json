{
  "manifest_version": 3,
  "name": "Hermes Browser Extension",
  "short_name": "Hermes Ext",
  "version": "0.1.10",
  "description": "Browser-native side panel for Hermes Agent \u2014 connect web context to your local or remote Hermes runtime.",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "extension/assets/icons/icon-16.png",
    "32": "extension/assets/icons/icon-32.png",
    "48": "extension/assets/icons/icon-48.png",
    "128": "extension/assets/icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "optional_permissions": [
    "audioCapture"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
      "default_title": "Open Hermes Browser Extension",
      "default_icon": {
        "16": "extension/assets/icons/icon-16.png",
        "32": "extension/assets/icons/icon-32.png",
        "48": "extension/assets/icons/icon-48.png",
        "128": "extension/assets/icons/icon-128.png"
      }
    },
  "background": {
    "service_worker": "extension/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "extension/sidepanel.html"
  },
  "sidebar_action": {
    "default_icon": {
      "16": "extension/assets/icons/icon-16.png",
      "32": "extension/assets/icons/icon-32.png",
      "48": "extension/assets/icons/icon-48.png",
      "128": "extension/assets/icons/icon-128.png"
    },
    "default_title": "Hermes Browser Extension",
    "default_panel": "extension/sidepanel.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+H",
        "mac": "Alt+H"
      },
      "description": "Open Hermes Browser Extension"
    },
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+H",
        "mac": "Command+Shift+H"
      },
      "description": "Open Hermes Browser Sidebar"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "extension/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data: blob:; connect-src http: https: wss:;"
  }
}
